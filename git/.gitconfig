[user]
	email = arkanus@gmail.com
	name = Marcos

[push]
  default = upstream

[pull]
  rebase = true

[fetch]
  all = true
  prune = true

; [url "git@github.com:"]
;   insteadOf = https://github.com/

[core]
  # only use full scren less on big texts
  pager = less -F -X
[init]
	defaultBranch = main
[alias]
	ssh = stash save
	a = add
	au = add -u
	c = commit
	cm = commit -m
	b = branch
	l = log --oneline
	d = diff
	dc = diff --cached
	ch = checkout
	amend = commit --amend
	qamend = commit --amend --no-edit
